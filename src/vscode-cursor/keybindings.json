[
  //
  // Unbinds
  //

  {
    "key": "cmd+n",
    "command": "-workbench.action.files.newUntitledFile"
  },
  {
    "key": "cmd+shift+n",
    "command": "-workbench.action.newWindow"
  },
  {
    "key": "cmd+shift+u",
    "command": "-workbench.action.output.toggleOutput"
  },
  {
    "key": "cmd+e",
    "command": "-actions.findWithSelection"
  },
  {
    "key": "cmd+i",
    "command": "-composer.startComposerPrompt"
  },
  {
    "key": "cmd+i",
    "command": "-editor.action.triggerSuggest"
  },
  {
    "key": "cmd+shift+i",
    "command": "-composer.newAgentChat"
  },
  {
    "key": "cmd+e",
    "command": "-cursor.composer.openAgentWindow"
  },
  {
    "key": "cmd+shift+b",
    "command": "-composer.openBrowserTab"
  },
  {
    "key": "cmd+shift+b",
    "command": "-workbench.action.tasks.build"
  },

  //
  // Tab navigation/manipulation
  //

  {
    "key": "f3",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "f4",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "cmd+h",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "cmd+l",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+tab",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+shift+tab",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "cmd+,",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "cmd+.",
    "command": "workbench.action.moveEditorRightInGroup"
  },
  {
    "key": "cmd+t",
    "command": "workbench.action.files.newUntitledFile"
  },
  {
    "key": "cmd+n",
    "command": "editor.action.moveSelectionToNextFindMatch",
    "when": "editorFocus"
  },
  {
    "key": "cmd+shift+n",
    "command": "editor.action.moveSelectionToPreviousFindMatch"
  },
  {
    "key": "cmd+shift+u",
    "command": "cursorRedo"
  },
  {
    "key": "cmd+alt+n",
    "command": "workbench.action.newWindow"
  },
  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+f",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+shift+j",
    "command": "editor.action.insertCursorBelow"
  },
  {
    "key": "alt+shift+k",
    "command": "editor.action.insertCursorAbove"
  },

  // Expand/Srhink Selection
  {
    "key": "cmd+o",
    "command": "editor.action.smartSelect.expand",
    "when": "editorTextFocus"
  },
  {
    "key": "cmd+shift+o",
    "command": "editor.action.smartSelect.shrink",
    "when": "editorTextFocus"
  },

  // Text jump/selection
  {
    "key": "alt+;",
    "command": "editor.action.jumpToBracket",
    "when": "editorTextFocus"
  },

  // fold/unfold
  {
    "key": "shift+cmd+[",
    "command": "editor.fold",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+cmd+]",
    "command": "editor.unfold",
    "when": "editorTextFocus"
  },

  //
  // Terminal
  //

  {
    "key": "cmd+e",
    "command": "workbench.action.togglePanel"
  },
  {
    "key": "f3",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "f4",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+h",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+l",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+t",
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+w",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+o",
    "command": "workbench.action.terminal.clear",
    "when": "terminalFocus"
  },

  //
  // Others
  //

  // Focus Git source control panel
  {
    "key": "shift+cmd+g",
    "command": "workbench.view.scm",
    "when": "workbench.scm.active"
  },

  // Go to definition (CMD + G)
  {
    "key": "cmd+g",
    "command": "editor.action.revealDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
  },

  // Send enter to terminal (fixed by claude code)
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b\r" }
  }
]
